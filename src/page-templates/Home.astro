---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import MembersModal from '../components/MembersModal.astro';
import SponsorsModal from '../components/SponsorsModal.astro';
import HomeIntroSection from '../components/home/HomeIntroSection.astro';
import HomeProductsSection from '../components/home/HomeProductsSection.astro';
import HomePartnersSection from '../components/home/HomePartnersSection.astro';
import HomeArticlesSection from '../components/home/HomeArticlesSection.astro';
import HomeAboutSection from '../components/home/HomeAboutSection.astro';
import { t, getLocalizedUrl } from '../i18n';
import { cynaraConfig } from '../config/cynara';
import partnersData from '../data/partners.json' assert { type: 'json' };
import productsZh from '../data/products.zh.json' assert { type: 'json' };
import productsEn from '../data/products.en.json' assert { type: 'json' };
import { getCollection } from 'astro:content';
interface Props { lang: any }
const { lang } = Astro.props;
const productsData = {
  zh: productsZh,
  en: productsEn,
};
const allArticles = await getCollection('articles', ({ data }: any) => {
  return import.meta.env.PROD ? data.draft !== true : true;
});
const pinnedArticles = allArticles
  .filter((article: any) => !cynaraConfig.articles.pinnedOnlyOnHome || article.data.pin === true)
  .sort((a: any, b: any) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, cynaraConfig.home.featuredArticles);

const featuredProductsData = {
  zh: productsData.zh.slice(0, cynaraConfig.home.featuredProducts),
  en: productsData.en.slice(0, cynaraConfig.home.featuredProducts),
};
---

<BaseLayout
  title={t(lang, 'nav.home')}
  lang={lang}
  showVideoBackground={true}
  description={lang === 'zh' ? 'Cynara 官方网站，展示产品、伙伴、专栏与团队动态。' : 'Cynara official website featuring products, partners, articles, and team updates.'}
>
  <div class="fullpage-wrapper" id="fullpageWrapper">
    <section class="fullpage-section" data-index="0" id="section0">
      <Hero lang={lang} />
    </section>

    <HomeIntroSection lang={lang} />
    <HomeProductsSection lang={lang} products={productsData} limit={cynaraConfig.home.featuredProducts} productsRoute={getLocalizedUrl(cynaraConfig.routes.products, lang)} />
    <HomePartnersSection lang={lang} partners={partnersData.partners} limit={cynaraConfig.home.featuredPartners} partnersRoute={getLocalizedUrl(cynaraConfig.routes.partners, lang)} contactEmail={cynaraConfig.external.contactEmail} />
    <HomeArticlesSection lang={lang} featuredArticles={pinnedArticles} />
    <HomeAboutSection lang={lang} />
  </div>

  <nav class="fixed right-6 top-1/2 -translate-y-1/2 z-50 flex flex-col gap-4" id="pageDots">
    <button class="page-dot active-dot" data-target="0"></button>
    <button class="page-dot" data-target="1"></button>
    <button class="page-dot" data-target="2"></button>
    <button class="page-dot" data-target="3"></button>
    <button class="page-dot" data-target="4"></button>
    <button class="page-dot" data-target="5"></button>
  </nav>

  <MembersModal lang={lang} isOpen={false} onClose={() => {}} />
  <SponsorsModal lang={lang} isOpen={false} onClose={() => {}} />

  <script is:inline define:vars={{ productsData: featuredProductsData }}>
    window.productsData = productsData;
  </script>

  <style is:global>
    .product-nav-btn.active {
      transform: scale(1.25);
    }

    .product-transition {
      transition: opacity 0.3s ease-in-out, transform 0.3s ease-in-out;
    }

    .product-hidden {
      opacity: 0;
      transform: scale(0.95);
    }

    .timer-value {
      display: inline-block;
      min-width: 2em;
      text-align: center;
      font-weight: bold;
      color: white;
    }
  </style>

  <script>
    interface ProductLink {
      text: string;
      url: string;
    }

    interface ProductItem {
      name: string;
      desc: string;
      iconPath: string;
      imagePath: string;
      links: ProductLink[];
    }

    type PageLang = 'zh' | 'en';
    type ProductsMap = Record<PageLang, ProductItem[]>;
    type AppWindow = Window & typeof globalThis & {
      productsData?: ProductsMap;
      scrollToSection?: (index: number) => void;
    };

    function initHomePage() {
      const appWindow = window as AppWindow;
      const wrapper = document.getElementById('fullpageWrapper');
      const dots = document.querySelectorAll<HTMLButtonElement>('#pageDots button');
      const sections = document.querySelectorAll<HTMLElement>('.fullpage-section');
      const shouldUseFullpage = window.matchMedia('(min-width: 768px)').matches;

      if (wrapper instanceof HTMLElement && shouldUseFullpage) {
        let currentIndex = 0;
        let isScrolling = false;
        let wheelTimeout: number | undefined;
        const scrollTimeout = 600;

        const updateActiveDot = () => {
          dots.forEach((dot, index) => {
            dot.classList.toggle('active-dot', index === currentIndex);
          });
        };

        const scrollToSection = (index: number) => {
          if (isScrolling || index < 0 || index >= sections.length) {
            return;
          }

          const nextSection = sections[index];
          if (!nextSection) {
            return;
          }

          isScrolling = true;
          currentIndex = index;
          nextSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
          updateActiveDot();

          window.setTimeout(() => {
            isScrolling = false;
          }, scrollTimeout);
        };

        appWindow.scrollToSection = scrollToSection;

        dots.forEach((dot) => {
          dot.addEventListener('click', () => {
            const target = Number.parseInt(dot.dataset.target ?? '', 10);
            if (!Number.isNaN(target)) {
              scrollToSection(target);
            }
          });
        });

        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            if (!(entry.target instanceof HTMLElement) || !entry.isIntersecting) {
              return;
            }

            const nextIndex = Number.parseInt(entry.target.dataset.index ?? '', 10);
            if (!Number.isNaN(nextIndex)) {
              currentIndex = nextIndex;
              updateActiveDot();
            }
          });
        }, {
          root: wrapper,
          threshold: 0.6
        });

        sections.forEach((section) => {
          observer.observe(section);
        });

        wrapper.addEventListener('wheel', (e) => {
          e.preventDefault();

          if (wheelTimeout) {
            clearTimeout(wheelTimeout);
          }

          wheelTimeout = window.setTimeout(() => {
            if (isScrolling) {
              return;
            }

            if (e.deltaY > 0) {
              scrollToSection(currentIndex + 1);
            } else if (e.deltaY < 0) {
              scrollToSection(currentIndex - 1);
            }
          }, 30);
        }, { passive: false });

        document.addEventListener('keydown', (e) => {
          if (isScrolling) {
            return;
          }

          if (e.key === 'ArrowDown' || e.key === 'PageDown') {
            e.preventDefault();
            scrollToSection(currentIndex + 1);
          } else if (e.key === 'ArrowUp' || e.key === 'PageUp') {
            e.preventDefault();
            scrollToSection(currentIndex - 1);
          }
        });

        window.addEventListener('load', () => {
          const sectionMatch = window.location.hash.match(/^#section(\d+)$/);
          if (!sectionMatch) {
            return;
          }

          const index = Number.parseInt(sectionMatch[1], 10);
          if (!Number.isNaN(index)) {
            window.setTimeout(() => {
              scrollToSection(index);
            }, 100);
          }
        });
      }

      const products = appWindow.productsData;
      const pageLang: PageLang = document.documentElement.lang === 'zh' ? 'zh' : 'en';
      const currentProducts = products?.[pageLang] ?? [];

      const productNameEl = document.getElementById('product-name');
      const productDescEl = document.getElementById('product-desc');
      const productSmallIconEl = document.getElementById('product-small-icon');
      const productLargeImageEl = document.getElementById('product-large-image');
      const productLinksEl = document.getElementById('product-links');
      const productNavBtns = document.querySelectorAll<HTMLButtonElement>('.product-nav-btn');

      if (
        currentProducts.length > 0 &&
        productNameEl &&
        productDescEl &&
        productSmallIconEl &&
        productLargeImageEl &&
        productLinksEl &&
        productNavBtns.length > 0
      ) {
        let productIndex = 0;
        let autoSwitchInterval: number | undefined;

        const updateProduct = (index: number) => {
          const product = currentProducts[index];
          if (!product) {
            return;
          }

          productIndex = index;
          productNameEl.textContent = product.name;
          productDescEl.textContent = product.desc;

          const oldIconImg = productSmallIconEl.querySelector<HTMLImageElement>('img');
          if (oldIconImg) {
            oldIconImg.src = product.iconPath;
          }

          const oldImageImg = productLargeImageEl.querySelector<HTMLImageElement>('img');
          if (oldImageImg) {
            oldImageImg.src = product.imagePath;
          }

          productLinksEl.innerHTML = '';
          product.links.forEach((link: ProductLink) => {
            const anchor = document.createElement('a');
            anchor.href = link.url;
            anchor.target = '_blank';
            anchor.rel = 'noopener noreferrer';
            anchor.className = 'glass-btn px-6 py-3 rounded-xl text-white font-medium hover:scale-105 transition-transform text-center whitespace-nowrap flex-1 sm:flex-none';
            anchor.textContent = link.text;
            productLinksEl.appendChild(anchor);
          });

          productNavBtns.forEach((btn, buttonIndex) => {
            btn.classList.toggle('active', buttonIndex === index);
          });
        };

        const startAutoSwitch = () => {
          autoSwitchInterval = window.setInterval(() => {
            const nextIndex = (productIndex + 1) % currentProducts.length;
            updateProduct(nextIndex);
          }, 5000);
        };

        const stopAutoSwitch = () => {
          if (autoSwitchInterval) {
            clearInterval(autoSwitchInterval);
          }
        };

        productNavBtns.forEach((btn) => {
          btn.addEventListener('click', () => {
            const index = Number.parseInt(btn.dataset.index ?? '', 10);
            if (Number.isNaN(index)) {
              return;
            }

            stopAutoSwitch();
            updateProduct(index);
            startAutoSwitch();
          });
        });

        startAutoSwitch();
      }

      const membersLink = document.getElementById('members-link');
      const membersModal = document.getElementById('members-modal');

      if (membersLink && membersModal) {
        membersLink.addEventListener('click', (e) => {
          e.preventDefault();
          membersModal.classList.remove('opacity-0', 'pointer-events-none');
        });
      }

      const sponsorsLink = document.getElementById('sponsors-link');
      const sponsorsModal = document.getElementById('sponsors-modal');

      if (sponsorsLink && sponsorsModal) {
        sponsorsLink.addEventListener('click', (e) => {
          e.preventDefault();
          sponsorsModal.classList.remove('opacity-0', 'pointer-events-none');
        });
      }
    }

    document.addEventListener('astro:page-load', initHomePage);
  </script>
</BaseLayout>
