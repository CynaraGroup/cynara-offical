---
import { t, type Locale } from '../../i18n';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
---

<section class="fullpage-section flex items-center justify-center" data-index="1" id="section1">
  <div class="max-w-7xl mx-auto px-5 md:px-6 w-full">
    <div class="flex flex-col lg:flex-row items-center gap-6 md:gap-8 lg:gap-12">
      <div class="flex-1 text-center lg:text-left">
        <span class="mb-3 inline-flex rounded-full border border-white/15 bg-white/10 px-4 py-1.5 text-xs font-semibold tracking-[0.22em] text-blue-100/90 backdrop-blur-md md:hidden">
          ABOUT
        </span>
        <h2 class="text-3xl md:text-5xl font-bold text-white mb-3 md:mb-6">{t(lang, 'home.introTitle')}</h2>
        <p class="mx-auto max-w-sm text-sm leading-7 text-gray-300 md:max-w-none md:text-xl md:leading-relaxed lg:mx-0">{t(lang, 'home.introDesc')}</p>
      </div>

      <div class="intro-feature-grid flex-1 grid grid-cols-2 md:grid-cols-2 gap-3 md:gap-6">
        <div class="intro-feature-card group glass-card p-4 md:p-8 rounded-3xl transition-all duration-500 hover:scale-105 hover:shadow-2xl">
          <div class="intro-feature-icon w-12 h-12 md:w-16 md:h-16 bg-gradient-to-br from-blue-500/20 to-blue-600/20 rounded-2xl flex items-center justify-center mb-3 md:mb-6 group-hover:rotate-12 transition-transform duration-300">
            <svg class="w-7 h-7 md:w-8 md:h-8 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="text-lg md:text-2xl font-bold mb-1.5 md:mb-3 text-white">{t(lang, 'home.introTech')}</h3>
          <p class="text-sm leading-6 text-gray-400 md:text-base md:leading-relaxed">{t(lang, 'home.introTechDesc')}</p>
        </div>

        <div class="intro-feature-card group glass-card p-4 md:p-8 rounded-3xl transition-all duration-500 hover:scale-105 hover:shadow-2xl">
          <div class="intro-feature-icon w-12 h-12 md:w-16 md:h-16 bg-gradient-to-br from-purple-500/20 to-purple-600/20 rounded-2xl flex items-center justify-center mb-3 md:mb-6 group-hover:rotate-12 transition-transform duration-300">
            <svg class="w-7 h-7 md:w-8 md:h-8 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
            </svg>
          </div>
          <h3 class="text-lg md:text-2xl font-bold mb-1.5 md:mb-3 text-white">{t(lang, 'home.introAesthetics')}</h3>
          <p class="text-sm leading-6 text-gray-400 md:text-base md:leading-relaxed">{t(lang, 'home.introAestheticsDesc')}</p>
        </div>

        <div class="intro-feature-card group glass-card p-4 md:p-8 rounded-3xl transition-all duration-500 hover:scale-105 hover:shadow-2xl">
          <div class="intro-feature-icon w-12 h-12 md:w-16 md:h-16 bg-gradient-to-br from-green-500/20 to-green-600/20 rounded-2xl flex items-center justify-center mb-3 md:mb-6 group-hover:rotate-12 transition-transform duration-300">
            <svg class="w-7 h-7 md:w-8 md:h-8 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
            </svg>
          </div>
          <h3 class="text-lg md:text-2xl font-bold mb-1.5 md:mb-3 text-white">{t(lang, 'home.introHumanity')}</h3>
          <p class="text-sm leading-6 text-gray-400 md:text-base md:leading-relaxed">{t(lang, 'home.introHumanityDesc')}</p>
        </div>

        <div class="intro-feature-card group glass-card p-4 md:p-8 rounded-3xl transition-all duration-500 hover:scale-105 hover:shadow-2xl">
          <div class="intro-feature-icon w-12 h-12 md:w-16 md:h-16 bg-gradient-to-br from-yellow-500/20 to-yellow-600/20 rounded-2xl flex items-center justify-center mb-3 md:mb-6 group-hover:rotate-12 transition-transform duration-300">
            <svg class="w-7 h-7 md:w-8 md:h-8 text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
            </svg>
          </div>
          <h3 class="text-lg md:text-2xl font-bold mb-1.5 md:mb-3 text-white">{t(lang, 'home.introInnovation')}</h3>
          <p class="text-sm leading-6 text-gray-400 md:text-base md:leading-relaxed">{t(lang, 'home.introInnovationDesc')}</p>
        </div>
      </div>
    </div>
  </div>
</section>
