---
import dayjs from 'dayjs';
import { t, type Locale } from '../../i18n';

interface Props {
  lang: Locale;
  startDate?: string;
}

const { lang, startDate = '2022-12-14' } = Astro.props;

const now = dayjs();
const baseDate = dayjs(startDate);
const initialDiff = Math.max(0, now.diff(baseDate));

const initialDays = Math.floor(initialDiff / (1000 * 60 * 60 * 24));
const initialHours = Math.floor((initialDiff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
const initialMinutes = Math.floor((initialDiff % (1000 * 60 * 60)) / (1000 * 60));
const initialSeconds = Math.floor((initialDiff % (1000 * 60)) / 1000);
---

<p class="text-gray-200" data-about-timer data-start-date={startDate}>
  {t(lang, 'aboutSection.timelineStart')}
  <span class="timer-value text-white font-bold mx-1" data-timer-part="days">{initialDays}</span>
  {t(lang, 'aboutSection.timelineDays')}
  <span class="timer-value text-white font-bold mx-1" data-timer-part="hours">{initialHours}</span>
  {t(lang, 'aboutSection.timelineHours')}
  <span class="timer-value text-white font-bold mx-1" data-timer-part="minutes">{initialMinutes}</span>
  {t(lang, 'aboutSection.timelineMinutes')}
  <span class="timer-value text-white font-bold mx-1" data-timer-part="seconds">{initialSeconds}</span>
  {t(lang, 'aboutSection.timelineSeconds')}
  {t(lang, 'aboutSection.timelineEnd')}
</p>

<script>
  import dayjs from 'dayjs';

  const timers = document.querySelectorAll<HTMLElement>('[data-about-timer]');

  timers.forEach((timer) => {
    if (timer.dataset.aboutTimerBound === 'true') {
      return;
    }

    timer.dataset.aboutTimerBound = 'true';

    const startDate = timer.dataset.startDate;
    if (!startDate) {
      return;
    }

    const daysEl = timer.querySelector<HTMLElement>('[data-timer-part="days"]');
    const hoursEl = timer.querySelector<HTMLElement>('[data-timer-part="hours"]');
    const minutesEl = timer.querySelector<HTMLElement>('[data-timer-part="minutes"]');
    const secondsEl = timer.querySelector<HTMLElement>('[data-timer-part="seconds"]');

    if (!daysEl || !hoursEl || !minutesEl || !secondsEl) {
      return;
    }

    const updateTimer = () => {
      try {
        const diff = Math.max(0, dayjs().diff(dayjs(startDate)));

        const days = Math.floor(diff / (1000 * 60 * 60 * 24));
        const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
        const seconds = Math.floor((diff % (1000 * 60)) / 1000);

        daysEl.textContent = String(days);
        hoursEl.textContent = String(hours);
        minutesEl.textContent = String(minutes);
        secondsEl.textContent = String(seconds);
      } catch (error) {
        console.error('About timer error:', error);
      }
    };

    updateTimer();
    window.setInterval(updateTimer, 1000);
  });
</script>
