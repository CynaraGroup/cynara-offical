---
import { getLocalizedUrl, type Locale } from '../../i18n';
import type { CollectionEntry } from 'astro:content';

interface Props {
  lang: Locale;
  featuredArticles: CollectionEntry<'articles'>[];
}

const { lang, featuredArticles } = Astro.props;
---

<section class="fullpage-section flex items-center justify-center" data-index="4" id="section4">
  <div class="max-w-7xl mx-auto px-5 md:px-6 w-full">
    <div class="flex flex-col items-start justify-between gap-4 mb-7 md:mb-10 sm:flex-row sm:items-center">
      <div>
        <h2 class="text-3xl md:text-5xl font-bold text-white">
          {lang === 'zh' ? '最新专栏' : 'Latest Articles'}
        </h2>
      </div>
      <a href={getLocalizedUrl('/articles', lang)} class="inline-flex items-center justify-center rounded-full border border-white/15 bg-white/10 px-6 py-3 text-sm font-semibold text-white backdrop-blur-xl shadow-[0_18px_40px_rgba(0,0,0,0.26)] transition-all duration-300 hover:-translate-y-0.5 hover:border-blue-200/40 hover:bg-blue-400/20 hover:shadow-[0_22px_48px_rgba(59,130,246,0.22)] md:px-7 md:py-3.5 md:text-base">
        {lang === 'zh' ? '查看全部' : 'View all'}
      </a>
    </div>

    <div class="grid grid-cols-1 gap-4 lg:grid-cols-3 lg:gap-6">
      {featuredArticles.length > 0 ? featuredArticles.map((article) => (
        <a href={getLocalizedUrl(`/articles/${article.slug}`, lang)} transition:name={`article-card-${article.slug}`} class="group glass-card rounded-3xl p-5 flex flex-col justify-between min-h-0 hover:bg-white/5 md:min-h-[20rem] md:p-6">
          <div>
            <div class="flex items-center gap-3 text-xs text-gray-400 mb-4">
              <time datetime={article.data.pubDate.toISOString()}>
                {article.data.pubDate.toLocaleDateString(lang === 'zh' ? 'zh-CN' : 'en-US', {
                  year: 'numeric',
                  month: 'short',
                  day: 'numeric',
                })}
              </time>
              {article.data.author && <span>{article.data.author}</span>}
            </div>
            <h3 class="text-xl font-bold text-white leading-snug group-hover:text-blue-300 transition-colors md:text-2xl">
              {article.data.title}
            </h3>
            {article.data.description && (
              <p class="mt-4 text-gray-300 leading-7 line-clamp-4">
                {article.data.description}
              </p>
            )}
          </div>

          {article.data.tags && article.data.tags.length > 0 && (
            <div class="mt-6 flex flex-wrap gap-2">
              {article.data.tags.map((tag: string) => (
                <span class="badge badge-outline rounded-full border-white/15 bg-white/5 px-3 py-3 text-xs text-gray-300 group-hover:border-blue-400/30 group-hover:bg-blue-500/20 group-hover:text-blue-200 transition-colors">
                  #{tag}
                </span>
              ))}
            </div>
          )}
        </a>
      )) : (
        <div class="glass-card rounded-3xl p-8 col-span-full text-center text-gray-400">
          {lang === 'zh' ? '暂无文章，敬请期待。' : 'No articles yet. Stay tuned.'}
        </div>
      )}
    </div>
  </div>
</section>
