---
import { t, type Locale } from '../i18n';
import sponsorsData from '../data/sponsors.json' assert { type: 'json' };

interface Props {
  lang: Locale;
  isOpen: boolean;
  onClose: () => void;
}

const { lang, isOpen, onClose } = Astro.props;
const sponsors = sponsorsData[lang];
---

<div id="sponsors-modal" class={`fixed inset-0 z-[100] flex items-center justify-center p-4 transition-opacity duration-300 ${isOpen ? 'opacity-100 pointer-events-auto' : 'opacity-0 pointer-events-none'}`}>
  <!-- 背景遮罩 -->
  <div class="absolute inset-0 bg-black/70 backdrop-blur-sm" id="sponsors-overlay" onclick="document.getElementById('sponsors-modal').classList.add('opacity-0', 'pointer-events-none');"></div>
  
  <!-- 弹窗内容 -->
  <div class="relative w-full max-w-4xl max-h-[85vh] glass-card rounded-3xl p-6 md:p-8 overflow-hidden flex flex-col">
    <!-- 标题栏 -->
    <div class="flex items-center justify-between mb-4 flex-shrink-0">
      <h2 class="text-2xl md:text-3xl font-bold text-white">{t(lang, 'aboutSection.sponsors')}</h2>
      <button id="sponsors-close-btn" class="w-10 h-10 flex items-center justify-center rounded-full hover:bg-white/10 transition-colors" onclick="document.getElementById('sponsors-modal').classList.add('opacity-0', 'pointer-events-none');">
        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
    
    <!-- 内容区 -->
    <div class="overflow-y-auto flex-1 pr-2 scrollbar-hide">
      <!-- 顶部区域 -->
      <div class="mb-8 text-center">
        <p class="text-gray-300 mb-4">
          {lang === 'zh' 
            ? '你的每一份支持，都会帮助我们持续优化产品与服务。' 
            : 'Every bit of your support helps us continuously improve our products and services.'}
        </p>
        <a href="https://ifdian.net/a/cynara" target="_blank" rel="noopener noreferrer" class="inline-block glass-btn px-8 py-3 rounded-xl text-white font-medium hover:scale-105 transition-transform bg-gradient-to-r from-blue-500/20 to-purple-500/20 border border-blue-400/30">
          {lang === 'zh' ? '前往赞助' : 'Become a Sponsor'}
        </a>
      </div>
      
      <!-- 高级赞助者 -->
      {sponsors.premium && sponsors.premium.length > 0 && (
        <div class="mb-8">
          <h3 class="text-xl font-bold text-white mb-4 flex items-center gap-2">
            <svg class="w-6 h-6 text-purple-400" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
            </svg>
            {lang === 'zh' ? '高级赞助者' : 'Premium Sponsors'}
          </h3>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
            {sponsors.premium.map((sponsor) => (
              <div class="glass-card rounded-2xl p-5 transition-all duration-300 hover:scale-[1.02] hover:shadow-xl border border-purple-400/30">
                <div class="flex items-start gap-4">
                  <div class="w-16 h-16 rounded-full overflow-hidden flex-shrink-0 ring-2 ring-purple-400/30">
                    <img src={sponsor.avatar} alt={sponsor.name} class="w-full h-full object-cover" />
                  </div>
                  <div class="flex-1 min-w-0">
                    <div class="flex items-center justify-between mb-2">
                      <h4 class="text-lg font-bold text-white truncate">{sponsor.name}</h4>
                      <span class="text-purple-400 font-semibold whitespace-nowrap ml-2">{sponsor.amount}</span>
                    </div>
                    <p class="text-gray-500 text-sm mb-2">{sponsor.date}</p>
                    <p class="text-gray-300 text-sm italic">"{sponsor.message}"</p>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      )}
      
      <!-- 普通赞助者 -->
      {sponsors.regular && sponsors.regular.length > 0 && (
        <div>
          <h3 class="text-xl font-bold text-white mb-4 flex items-center gap-2">
            <svg class="w-6 h-6 text-gray-400" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/>
            </svg>
            {lang === 'zh' ? '赞助者' : 'Sponsors'}
          </h3>
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-3">
            {sponsors.regular.map((sponsor) => (
              <div class="glass-card rounded-xl p-4 transition-all duration-300 hover:scale-[1.02] border border-gray-400/20">
                <div class="flex items-center justify-between">
                  <span class="text-white font-medium">{sponsor.name}</span>
                  <span class="text-gray-400 font-semibold">{sponsor.amount}</span>
                </div>
                <p class="text-gray-500 text-xs mt-1">{sponsor.date}</p>
              </div>
            ))}
          </div>
        </div>
      )}
      
      <!-- 如果没有赞助者 -->
      {(!sponsors.premium || sponsors.premium.length === 0) && (!sponsors.regular || sponsors.regular.length === 0) && (
        <div class="text-center py-12">
          <p class="text-gray-500 text-lg">
            {lang === 'zh' ? '暂无赞助者，成为第一个支持者吧！' : 'No sponsors yet, be the first to support us!'}
          </p>
        </div>
      )}
    </div>
  </div>
</div>

<script is:inline>
  // 键盘 ESC 关闭
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      const modal = document.getElementById('sponsors-modal');
      if (modal && !modal.classList.contains('opacity-0')) {
        modal.classList.add('opacity-0', 'pointer-events-none');
      }
    }
  });
</script>

<style is:global>
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
