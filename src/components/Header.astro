---
import { t, type Locale, getLocalizedUrl } from '../i18n';
import { cynaraConfig } from '../config/cynara';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const homeRoute = getLocalizedUrl(cynaraConfig.routes.home, lang);
const articlesRoute = getLocalizedUrl(cynaraConfig.routes.articles, lang);
const contactRoute = getLocalizedUrl('/contact', lang);
const accountCenterUrl = 'https://account.mahiro.work';
const accountCenterLabel = t(lang, 'nav.account');
const targetLang = lang === 'zh' ? 'en' : 'zh';
const targetLangLabel = lang === 'zh' ? 'EN' : '中文';
const toggleHref = getLocalizedUrl(Astro.url.pathname + Astro.url.search + Astro.url.hash, targetLang);
const navItemClass = 'flex flex-col items-center gap-1 px-2 py-3 rounded-lg text-xs font-medium transition-all hover:bg-white/10';
const mobileNavItemClass = 'flex flex-col items-center gap-0.5 px-3 py-1.5 rounded-xl text-[10px] font-medium text-white/60 hover:text-white hover:bg-white/10 transition-all';
---

<aside id="sidebar" class="fixed top-0 left-0 z-50 hidden h-full w-24 glass-sidebar md:block lg:w-26">
  <div class="flex h-full flex-col p-3 text-white">
    <nav class="flex-1 space-y-1 pt-3">
      <a href={homeRoute} class={`nav-home ${navItemClass}`}>
        <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l9-9 9 9M5 10v10a1 1 0 001 1h4v-6h4v6h4a1 1 0 001-1V10" />
        </svg>
        {t(lang, 'nav.home')}
      </a>
      <a href={`${homeRoute}#section1`} class={`nav-intro ${navItemClass}`}>
        <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M12 21a9 9 0 110-18 9 9 0 010 18z" />
        </svg>
        {t(lang, 'nav.intro')}
      </a>
      <a href={`${homeRoute}#section2`} class={`nav-products ${navItemClass}`}>
        <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
        {t(lang, 'nav.products')}
      </a>
      <a href={`${homeRoute}#section3`} class={`nav-partners ${navItemClass}`}>
        <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.36-1.86M17 20H7m10 0v-2c0-.66-.13-1.28-.36-1.86M7 20H2v-2a3 3 0 015.36-1.86M7 20v-2c0-.66.13-1.28.36-1.86m0 0a5 5 0 019.28 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
        </svg>
        {t(lang, 'nav.partners')}
      </a>
      <a href={`${homeRoute}#section4`} class={`nav-articles ${navItemClass}`}>
        <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9.5A2.5 2.5 0 0016.5 7H15" />
        </svg>
        {t(lang, 'nav.articles')}
      </a>
      <a href={`${homeRoute}#section5`} class={`nav-about ${navItemClass}`}>
        <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
        </svg>
        {t(lang, 'nav.about')}
      </a>
      <a href={accountCenterUrl} class={`nav-account ${navItemClass}`} target="_blank" rel="noopener noreferrer">
        <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 12a4 4 0 100-8 4 4 0 000 8zm0 2c-4.42 0-8 2.24-8 5v1h16v-1c0-2.76-3.58-5-8-5z" />
        </svg>
        {accountCenterLabel}
      </a>
    </nav>

    <div class="mt-auto pt-4">
      <a href={toggleHref} class={`${navItemClass} group`} data-astro-reload>
        <svg class="h-6 w-6 text-gray-400 transition-colors group-hover:text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5h12M9 3v2m1.05 9.5A18.02 18.02 0 016.41 9m6.09 9h7M11 21l5-10 5 10M12.75 5C11.78 10.77 8.07 15.61 3 18.13" />
        </svg>
        <span class="text-gray-400 transition-colors group-hover:text-white">{targetLangLabel}</span>
      </a>
    </div>
  </div>
</aside>

<div class="fixed right-5 top-5 z-[60] flex items-center gap-3 md:hidden">
  <a href={toggleHref} class="flex h-10 w-10 items-center justify-center rounded-xl border border-white/10 bg-white/10 text-white shadow-lg backdrop-blur-md transition-all hover:bg-white/20" data-astro-reload>
    <span class="text-xs font-bold">{targetLangLabel}</span>
  </a>
</div>

<nav class="mobile-bottom-nav fixed bottom-0 left-0 right-0 z-50 md:hidden">
  <div class="flex items-center justify-around px-1 py-1.5" style="padding-bottom: max(0.375rem, env(safe-area-inset-bottom));">
    <a href={homeRoute} class={`nav-home ${mobileNavItemClass}`}>
      <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l9-9 9 9M5 10v10a1 1 0 001 1h4v-6h4v6h4a1 1 0 001-1V10" />
      </svg>
      <span>{t(lang, 'nav.home')}</span>
    </a>
    <a href={`${homeRoute}#section2`} class={`nav-products ${mobileNavItemClass}`}>
      <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
      </svg>
      <span>{t(lang, 'nav.products')}</span>
    </a>
    <a href={articlesRoute} class={mobileNavItemClass}>
      <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9.5A2.5 2.5 0 0016.5 7H15" />
      </svg>
      <span>{t(lang, 'nav.articles')}</span>
    </a>
    <a href={`${homeRoute}#section5`} class={`nav-about ${mobileNavItemClass}`}>
      <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
      </svg>
      <span>{t(lang, 'nav.about')}</span>
    </a>
    <a href={contactRoute} class={mobileNavItemClass}>
      <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
      </svg>
      <span>{t(lang, 'nav.contact')}</span>
    </a>
    <a href={accountCenterUrl} class={mobileNavItemClass} target="_blank" rel="noopener noreferrer">
      <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 12a4 4 0 100-8 4 4 0 000 8zm0 2c-4.42 0-8 2.24-8 5v1h16v-1c0-2.76-3.58-5-8-5z" />
      </svg>
      <span>{accountCenterLabel}</span>
    </a>
  </div>
</nav>

<script is:inline define:vars={{ homeRoute }}>
  function isHomePath() {
    return window.location.pathname === homeRoute || window.location.pathname === '/' || window.location.pathname === '';
  }

  function bindHomeNav() {
    const links = document.querySelectorAll('.nav-home');
    if (!links.length) return;

    links.forEach((link) => {
      link.addEventListener('click', (event) => {
        if (!isHomePath()) return;

        event.preventDefault();
        if (window.scrollToSection) {
          window.scrollToSection(0);
          return;
        }

        const section = document.getElementById('section0');
        if (section) {
          section.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
      });
    });
  }

  function bindSectionNav(selector, index, fallbackId) {
    const links = document.querySelectorAll(selector);
    if (!links.length) return;

    links.forEach((link) => {
      link.addEventListener('click', (event) => {
        event.preventDefault();

        if (isHomePath()) {
          if (window.scrollToSection) {
            window.scrollToSection(index);
            return;
          }

          const section = document.getElementById(fallbackId);
          if (section) {
            section.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
          return;
        }

        window.location.href = `${homeRoute}#${fallbackId}`;
      });
    });
  }

  bindHomeNav();
  bindSectionNav('.nav-intro', 1, 'section1');
  bindSectionNav('.nav-products', 2, 'section2');
  bindSectionNav('.nav-partners', 3, 'section3');
  bindSectionNav('.nav-articles', 4, 'section4');
  bindSectionNav('.nav-about', 5, 'section5');
</script>
