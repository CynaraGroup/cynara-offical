---
import { t, type Locale } from '../i18n';
import { cynaraConfig } from '../config/cynara';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const homeRoute = cynaraConfig.routes.home;

// Calculate language toggle URL
const targetLang = lang === 'zh' ? 'en' : 'zh';
const targetLangLabel = lang === 'zh' ? 'EN' : '中文';
const currentUrl = new URL(Astro.url);
currentUrl.searchParams.set('lang', targetLang);
const toggleHref = `${currentUrl.pathname}${currentUrl.search}${currentUrl.hash}`;
---

<aside id="sidebar" class="fixed top-0 left-0 h-full w-0 md:w-24 lg:w-26 z-50 glass-sidebar">
  <div class="h-full flex flex-col p-3 text-white">
    <nav class="flex-1 space-y-1 pt-3">
      <a href={homeRoute} class="flex flex-col items-center gap-1 px-2 py-3 rounded-lg text-xs font-medium transition-all hover:bg-white/10">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
        </svg>
        {t(lang, 'nav.home')}
      </a>
      <a href={`${homeRoute}#section1`} class="nav-intro flex flex-col items-center gap-1 px-2 py-3 rounded-lg text-xs font-medium transition-all hover:bg-white/10">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        {t(lang, 'nav.intro')}
      </a>
      <a href={`${homeRoute}#section2`} class="nav-products flex flex-col items-center gap-1 px-2 py-3 rounded-lg text-xs font-medium transition-all hover:bg-white/10">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
        </svg>
        {t(lang, 'nav.products')}
      </a>
      <a href={`${homeRoute}#section3`} class="nav-partners flex flex-col items-center gap-1 px-2 py-3 rounded-lg text-xs font-medium transition-all hover:bg-white/10">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
        </svg>
        {t(lang, 'nav.partners')}
      </a>
      <a href={`${homeRoute}#section4`} class="nav-articles flex flex-col items-center gap-1 px-2 py-3 rounded-lg text-xs font-medium transition-all hover:bg-white/10">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 20H5a2 2 0 01-2-2V6a2 2 0 012-2h10a2 2 0 012 2v1m2 13a2 2 0 01-2-2V7m2 13a2 2 0 002-2V9.5a2.5 2.5 0 00-2.5-2.5H15" />
        </svg>
        {t(lang, 'nav.articles')}
      </a>
      <a href={`${homeRoute}#section5`} class="nav-about flex flex-col items-center gap-1 px-2 py-3 rounded-lg text-xs font-medium transition-all hover:bg-white/10">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
        </svg>
        {t(lang, 'nav.about')}
      </a>
    </nav>

    <div class="mt-auto pt-4">
      <a href={toggleHref} class="flex flex-col items-center gap-1 px-2 py-3 rounded-lg text-xs font-medium transition-all hover:bg-white/10 group" data-astro-reload>
        <svg class="w-6 h-6 text-gray-400 group-hover:text-white transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h7M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129" />
        </svg>
        <span class="text-gray-400 group-hover:text-white transition-colors">{targetLangLabel}</span>
      </a>
    </div>
  </div>
</aside>

<button id="mobileMenuBtn" class="hidden">
  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
  </svg>
</button>

<div id="mobileOverlay" class="hidden"></div>

<script is:inline define:vars={{ homeRoute }}>
  const sidebar = document.getElementById('sidebar');
  const mobileMenuBtn = document.getElementById('mobileMenuBtn');
  const mobileOverlay = document.getElementById('mobileOverlay');

  function toggleMobileMenu() {
    sidebar.classList.toggle('w-24');
    sidebar.classList.toggle('w-0');
    mobileOverlay.classList.toggle('hidden');
    document.body.classList.toggle('overflow-hidden');
  }

  if (mobileMenuBtn) {
    mobileMenuBtn.addEventListener('click', toggleMobileMenu);
  }

  if (mobileOverlay) {
    mobileOverlay.addEventListener('click', toggleMobileMenu);
  }

  function bindSectionNav(selector, index, fallbackId) {
    const link = document.querySelector(selector);
    if (!link) return;

    link.addEventListener('click', (e) => {
      e.preventDefault();
      if (window.location.pathname === homeRoute || window.location.pathname === '/' || window.location.pathname === '') {
        if (window.scrollToSection) {
          window.scrollToSection(index);
        } else {
          const section = document.getElementById(fallbackId);
          if (section) {
            section.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        }
      } else {
        window.location.href = `${homeRoute}#${fallbackId}`;
      }
    });
  }

  bindSectionNav('.nav-intro', 1, 'section1');
  bindSectionNav('.nav-products', 2, 'section2');
  bindSectionNav('.nav-partners', 3, 'section3');
  bindSectionNav('.nav-articles', 4, 'section4');
  bindSectionNav('.nav-about', 5, 'section5');
</script>
