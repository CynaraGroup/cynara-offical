---
import { t, type Locale } from '../i18n';
import membersData from '../data/members.json' assert { type: 'json' };

interface Props {
  lang: Locale;
  isOpen: boolean;
  onClose: () => void;
}

interface Member {
  avatar: string;
  name: string;
  role: string;
  bio: string;
}

const { lang, isOpen } = Astro.props as Props;
const localizedMembers = membersData as Partial<Record<Locale, Member[]>> & { zh?: Member[] };
const members = localizedMembers[lang] ?? localizedMembers.zh ?? [];
---

<div id="members-modal" class={`fixed inset-0 z-[100] flex items-center justify-center p-3 md:p-4 transition-opacity duration-300 ${isOpen ? 'opacity-100 pointer-events-auto' : 'opacity-0 pointer-events-none'}`}>
  <!-- 背景遮罩 -->
  <div class="absolute inset-0 bg-black/70 backdrop-blur-sm" id="modal-overlay" onclick="document.getElementById('members-modal').classList.add('opacity-0', 'pointer-events-none');"></div>
  
  <!-- 弹窗内容 -->
  <div class="relative w-full max-w-5xl max-h-[88svh] glass-card rounded-3xl p-4 md:max-h-[85vh] md:p-8 overflow-hidden flex flex-col">
    <!-- 标题栏 -->
    <div class="flex items-center justify-between mb-4 md:mb-6 flex-shrink-0">
      <h2 class="text-2xl md:text-3xl font-bold text-white">{t(lang, 'aboutSection.members')}</h2>
      <button id="modal-close-btn" class="w-10 h-10 flex items-center justify-center rounded-full hover:bg-white/10 transition-colors" onclick="document.getElementById('members-modal').classList.add('opacity-0', 'pointer-events-none');">
        <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    </div>
    
    <!-- 成员卡片网格 -->
    <div class="overflow-y-auto flex-1 pr-2 scrollbar-hide" id="members-scroll-container">
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-6">
        {members.map((member) => (
          <div class="glass-card rounded-2xl p-5 transition-all duration-300 hover:scale-[1.02] hover:shadow-xl group">
            <div class="flex flex-col items-center text-center">
              <!-- 头像 -->
              <div class="w-20 h-20 md:w-24 md:h-24 rounded-full overflow-hidden mb-4 ring-2 ring-white/20 group-hover:ring-white/40 transition-all">
                <img src={member.avatar} alt={member.name} class="w-full h-full object-cover" />
              </div>
              
              <!-- 姓名 -->
              <h3 class="text-lg md:text-xl font-bold text-white mb-1">{member.name}</h3>
              
              <!-- 职务 -->
              <p class="text-blue-400 text-sm md:text-base font-medium mb-3">{member.role}</p>
              
              <!-- 介绍 -->
              <p class="text-gray-400 text-sm leading-relaxed">{member.bio}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</div>

<script is:inline>
  // 键盘 ESC 关闭
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      const modal = document.getElementById('members-modal');
      if (modal && !modal.classList.contains('opacity-0')) {
        modal.classList.add('opacity-0', 'pointer-events-none');
      }
    }
  });
</script>

<style is:global>
  #members-modal::-webkit-scrollbar {
    display: none;
  }
  
  #members-modal {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
  
  .scrollbar-hide::-webkit-scrollbar {
    display: none;
  }
  
  .scrollbar-hide {
    -ms-overflow-style: none;
    scrollbar-width: none;
  }
</style>
