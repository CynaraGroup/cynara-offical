---
import { t, type Locale } from '../i18n';
import { cynaraConfig } from '../config/cynara';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;
const homeRoute = cynaraConfig.routes.home;
---

<footer class="mt-24 py-16 border-t border-white/10">
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12">
      <div class="md:col-span-2">
        <a href={homeRoute} class="flex items-center gap-3">
          <img src={cynaraConfig.site.logo} alt={cynaraConfig.site.name} class="h-10 w-10 brightness-200" />
          <span class="text-xl font-semibold tracking-tight">{cynaraConfig.site.name}</span>
        </a>
        <p class="mt-4 text-gray-400 text-sm leading-relaxed max-w-md">
          {t(lang, 'footer.tagline')}
        </p>
      </div>
      <div>
        <h4 class="text-sm font-medium text-gray-300 mb-4">{t(lang, 'footer.nav')}</h4>
        <ul class="space-y-2">
          <li><a href={homeRoute} class="text-sm text-gray-400 hover:text-white transition-colors">{t(lang, 'nav.home')}</a></li>
          <li><a href={`${homeRoute}#section1`} class="text-sm text-gray-400 hover:text-white transition-colors">{t(lang, 'nav.intro')}</a></li>
          <li><a href={`${homeRoute}#section2`} class="text-sm text-gray-400 hover:text-white transition-colors">{t(lang, 'nav.products')}</a></li>
          <li><a href={`${homeRoute}#section3`} class="text-sm text-gray-400 hover:text-white transition-colors">{t(lang, 'nav.partners')}</a></li>
          <li><a href={`${homeRoute}#section4`} class="text-sm text-gray-400 hover:text-white transition-colors">{t(lang, 'nav.about')}</a></li>
          <li><a href="/contact" class="text-sm text-gray-400 hover:text-white transition-colors">{t(lang, 'nav.contact')}</a></li>
        </ul>
      </div>
      <div>
        <h4 class="text-sm font-medium text-gray-300 mb-4">{t(lang, 'footer.contact')}</h4>
        <ul class="space-y-2 text-sm text-gray-400">
          <li>{cynaraConfig.external.contactEmail}</li>
        </ul>
      </div>
    </div>
    <div class="mt-12 pt-8 border-t border-white/10 flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-sm text-gray-500">{t(lang, 'footer.copyright')}</p>
    </div>
  </div>
</footer>
