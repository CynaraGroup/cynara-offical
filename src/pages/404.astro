---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getLocaleFromUrl } from '../i18n';
import { cynaraConfig } from '../config/cynara';

const lang = getLocaleFromUrl(Astro.url);
const homeRoute = cynaraConfig.routes.home;
---

<BaseLayout
  title={lang === 'zh' ? '页面未找到' : 'Page Not Found'}
  lang={lang}
  showVideoBackground={true}
  noindex={true}
  description={lang === 'zh' ? '您访问的页面不存在。' : 'The page you are looking for does not exist.'}
>
  <div class="relative z-10 flex min-h-screen flex-col items-center justify-center px-6 text-center">
    <div class="error-card glass-card max-w-lg rounded-[2.5rem] p-10 md:p-14">
      <p class="error-code mb-2 text-[8rem] font-black leading-none tracking-tighter md:text-[10rem]">
        4<span class="text-accent-gradient">0</span>4
      </p>

      <h1 class="mt-2 text-2xl font-bold text-white md:text-3xl">
        {lang === 'zh' ? '页面未找到' : 'Page Not Found'}
      </h1>

      <p class="mt-4 text-base leading-7 text-gray-400">
        {lang === 'zh'
          ? '您访问的页面不存在，可能已被移除或链接有误。'
          : 'The page you are looking for might have been removed or the link might be incorrect.'}
      </p>

      <div class="mt-8 flex flex-col items-center gap-3 sm:flex-row sm:justify-center">
        <a
          href={homeRoute}
          class="glass-btn inline-flex items-center gap-2 rounded-xl px-6 py-3 text-sm font-semibold text-white transition-all hover:scale-105 hover:border-blue-300/40 hover:bg-blue-500/20"
        >
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
          </svg>
          {lang === 'zh' ? '返回首页' : 'Back to Home'}
        </a>

        <button
          onclick="history.back()"
          class="inline-flex items-center gap-2 rounded-xl border border-white/10 bg-transparent px-6 py-3 text-sm font-medium text-gray-300 transition-all hover:border-white/20 hover:text-white"
        >
          <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
          </svg>
          {lang === 'zh' ? '返回上一页' : 'Go Back'}
        </button>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .text-accent-gradient {
    background: linear-gradient(135deg, #7dc8e5 0%, #ffb6c1 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .error-code {
    color: rgba(255, 255, 255, 0.08);
    text-shadow:
      0 0 80px rgba(125, 200, 229, 0.15),
      0 0 160px rgba(255, 182, 193, 0.08);
  }

  .error-card {
    position: relative;
    overflow: hidden;
  }

  .error-card::before {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: inherit;
    pointer-events: none;
    background:
      radial-gradient(circle at 30% 20%, rgba(125, 200, 229, 0.12), transparent 50%),
      radial-gradient(circle at 70% 80%, rgba(255, 182, 193, 0.08), transparent 50%);
  }

  @media (max-width: 767px) {
    .error-card {
      border-radius: 1.5rem;
      padding: 2rem 1.5rem;
    }

    .error-code {
      font-size: 6rem;
    }
  }
</style>
