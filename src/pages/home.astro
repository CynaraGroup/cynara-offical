---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import MembersModal from '../components/MembersModal.astro';
import SponsorsModal from '../components/SponsorsModal.astro';
import { t, defaultLocale, type Locale } from '../i18n';
import partnersData from '../data/partners.json' assert { type: 'json' };
import productsData from '../data/products.json' assert { type: 'json' };

function getLang(): Locale {
  // 1. 从 URL 参数获取
  const url = new URL(Astro.request.url);
  const langFromUrl = url.searchParams.get('lang');
  
  // 2. 如果 URL 中有语言参数，设置到 cookie
  if (langFromUrl === 'zh' || langFromUrl === 'en') {
    Astro.cookies.set('lang', langFromUrl, {
      path: '/',
      maxAge: 31536000,
    });
    return langFromUrl;
  }
  
  // 3. 从 cookie 获取
  const langCookie = Astro.cookies.get('lang');
  if (langCookie?.value === 'zh' || langCookie?.value === 'en') {
    return langCookie.value;
  }
  
  // 4. 默认值
  return defaultLocale;
}

const lang = getLang();
---

<BaseLayout title={t(lang, 'nav.home')} lang={lang} showVideoBackground={true}>
  <div class="fullpage-wrapper" id="fullpageWrapper">
    <section class="fullpage-section" data-index="0" id="section0">
      <Hero lang={lang} />
    </section>
    
    <section class="fullpage-section flex items-center justify-center" data-index="1" id="section1">
      <div class="max-w-7xl mx-auto px-6 w-full">
        <div class="flex flex-col lg:flex-row items-center gap-12">
          <div class="flex-1 text-center lg:text-left">
            <h2 class="text-4xl md:text-5xl font-bold text-white mb-6">{t(lang, 'home.introTitle')}</h2>
            <p class="text-xl text-gray-300 leading-relaxed">{t(lang, 'home.introDesc')}</p>
          </div>
          
          <div class="flex-1 grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="group glass-card p-8 rounded-3xl transition-all duration-500 hover:scale-105 hover:shadow-2xl">
              <div class="w-16 h-16 bg-gradient-to-br from-blue-500/20 to-blue-600/20 rounded-2xl flex items-center justify-center mb-6 group-hover:rotate-12 transition-transform duration-300">
                <svg class="w-8 h-8 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                </svg>
              </div>
              <h3 class="text-2xl font-bold mb-3 text-white">{t(lang, 'home.introTech')}</h3>
              <p class="text-gray-400 leading-relaxed">{t(lang, 'home.introTechDesc')}</p>
            </div>
            
            <div class="group glass-card p-8 rounded-3xl transition-all duration-500 hover:scale-105 hover:shadow-2xl">
              <div class="w-16 h-16 bg-gradient-to-br from-purple-500/20 to-purple-600/20 rounded-2xl flex items-center justify-center mb-6 group-hover:rotate-12 transition-transform duration-300">
                <svg class="w-8 h-8 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z" />
                </svg>
              </div>
              <h3 class="text-2xl font-bold mb-3 text-white">{t(lang, 'home.introAesthetics')}</h3>
              <p class="text-gray-400 leading-relaxed">{t(lang, 'home.introAestheticsDesc')}</p>
            </div>
            
            <div class="group glass-card p-8 rounded-3xl transition-all duration-500 hover:scale-105 hover:shadow-2xl">
              <div class="w-16 h-16 bg-gradient-to-br from-green-500/20 to-green-600/20 rounded-2xl flex items-center justify-center mb-6 group-hover:rotate-12 transition-transform duration-300">
                <svg class="w-8 h-8 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                </svg>
              </div>
              <h3 class="text-2xl font-bold mb-3 text-white">{t(lang, 'home.introHumanity')}</h3>
              <p class="text-gray-400 leading-relaxed">{t(lang, 'home.introHumanityDesc')}</p>
            </div>
            
            <div class="group glass-card p-8 rounded-3xl transition-all duration-500 hover:scale-105 hover:shadow-2xl">
              <div class="w-16 h-16 bg-gradient-to-br from-yellow-500/20 to-yellow-600/20 rounded-2xl flex items-center justify-center mb-6 group-hover:rotate-12 transition-transform duration-300">
                <svg class="w-8 h-8 text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.663 17h4.673M12 3v1m6.364 1.636l-.707.707M21 12h-1M4 12H3m3.343-5.657l-.707-.707m2.828 9.9a5 5 0 117.072 0l-.548.547A3.374 3.374 0 0014 18.469V19a2 2 0 11-4 0v-.531c0-.895-.356-1.754-.988-2.386l-.548-.547z" />
                </svg>
              </div>
              <h3 class="text-2xl font-bold mb-3 text-white">{t(lang, 'home.introInnovation')}</h3>
              <p class="text-gray-400 leading-relaxed">{t(lang, 'home.introInnovationDesc')}</p>
            </div>
          </div>
        </div>
      </div>
    </section>
    

    
    <section class="fullpage-section flex items-center justify-center" data-index="2" id="section2">
      <div class="max-w-7xl mx-auto px-6 w-full">
        <div class="flex justify-end mb-12">
          <h2 class="text-4xl md:text-5xl font-bold text-white">{t(lang, 'products.title')}</h2>
        </div>
        
        <div class="flex gap-8 items-center">
          <div class="flex-1">
            <div class="flex flex-col items-start justify-center gap-6">
              <div class="flex items-center gap-4">
                <div id="product-small-icon" class="flex items-center justify-center">
                  <img src={productsData[lang][0].iconPath} alt="Product" class="w-16 h-16 object-contain" />
                </div>
                <h3 class="text-2xl font-bold text-white" id="product-name">{productsData[lang][0].name}</h3>
              </div>
              
              <p class="text-gray-300 text-lg leading-relaxed max-w-md" id="product-desc">{productsData[lang][0].desc}</p>
              
              <div class="product-links grid grid-cols-2 gap-3" id="product-links">
                {productsData[lang][0].links.map((link, index) => (
                  <a 
                    href={link.url} 
                    target="_blank" 
                    rel="noopener noreferrer"
                    class="glass-btn px-6 py-3 rounded-xl text-white font-medium hover:scale-105 transition-transform text-center"
                  >
                    {link.text}
                  </a>
                ))}
              </div>
            </div>
          </div>
          
          <div class="flex-[3.5]">
            <div class="aspect-video w-full rounded-2xl overflow-hidden bg-white/5" id="product-large-image">
              <img src={productsData[lang][0].imagePath} alt="Product" class="w-full h-full object-cover" />
            </div>
          </div>
          
          <div class="flex flex-col gap-4">
            {productsData[lang].map((product, index) => (
              <button 
                class={`product-nav-btn ${index === 0 ? 'active' : ''} w-16 h-16 flex items-center justify-center hover:scale-105 transition-all`}
                data-index={index}
              >
                <img src={product.iconPath} alt={`Product ${index + 1}`} class="w-8 h-8 object-contain" />
              </button>
            ))}
          </div>
        </div>
      </div>
    </section>
    
    <section class="fullpage-section flex items-center justify-center" data-index="3" id="section3">
      <div class="max-w-7xl mx-auto px-6 w-full">
        <div class="flex flex-col items-start gap-8">
          <div class="flex flex-col gap-4">
            <h2 class="text-4xl md:text-5xl font-bold text-white">{t(lang, 'partners.title')}</h2>
            <p class="text-xl text-gray-300">
              {t(lang, 'partners.description')}
              <a href="mailto:zhngjah3@outlook.com" class="hover:opacity-80">
                Email
              </a>
              {t(lang, 'partners.description2')}
            </p>
          </div>
          
          <div class="grid grid-cols-2 md:grid-cols-4 gap-6 w-full">
            {partnersData.partners.map((partner) => (
              <a 
                href={partner.url} 
                target="_blank" 
                rel="noopener noreferrer"
                class="partner-card glass-card aspect-[4/3] rounded-2xl p-4 flex items-center justify-center transition-all duration-300 hover:scale-105 hover:shadow-2xl relative overflow-hidden"
              >
                <img 
                  src={partner.logo} 
                  alt={partner.name} 
                  class="w-full h-full object-contain opacity-90"
                />
                <div class="absolute inset-0 bg-black/60 opacity-0 hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
                  <span class="text-white text-lg font-semibold text-center px-4">{partner.name}</span>
                </div>
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="fullpage-section flex items-center justify-center" data-index="4" id="section4">
      <div class="max-w-7xl mx-auto px-6 w-full">
        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 w-full">
          <div class="lg:col-span-2">
            <div class="glass-card p-8 rounded-3xl">
              <div class="mb-6">
                <h2 class="text-4xl md:text-5xl font-bold text-white mb-2">{t(lang, 'aboutSection.title')}</h2>
                <p class="text-gray-400 text-sm">{t(lang, 'aboutSection.subtitle')}</p>
              </div>
              
              <div class="space-y-6">
                <p class="text-gray-300 text-lg leading-relaxed">
                  {t(lang, 'aboutSection.description')}
                </p>
                
                <p class="text-gray-200">
                  {t(lang, 'aboutSection.timelineStart')}
                  <span class="timer-value text-white font-bold mx-1" id="timer-days">0</span>
                  {t(lang, 'aboutSection.timelineDays')}
                  <span class="timer-value text-white font-bold mx-1" id="timer-hours">0</span>
                  {t(lang, 'aboutSection.timelineHours')}
                  <span class="timer-value text-white font-bold mx-1" id="timer-minutes">0</span>
                  {t(lang, 'aboutSection.timelineMinutes')}
                  <span class="timer-value text-white font-bold mx-1" id="timer-seconds">0</span>
                  {t(lang, 'aboutSection.timelineSeconds')}
                  {t(lang, 'aboutSection.timelineEnd')}
                </p>
                
                <p class="text-gray-400 italic">
                  {t(lang, 'aboutSection.journey')}
                </p>
                
                <div class="space-y-4">
                  <p class="text-gray-300">
                    {t(lang, 'aboutSection.social')}
                    <a href="https://space.bilibili.com/3706979616819218" class="hover:opacity-80 mx-1" target="_blank">
                      {t(lang, 'aboutSection.socialBilibili')}
                    </a>
                  </p>
                  
                  <div class="flex flex-wrap gap-2 text-gray-400 text-sm">
                    <a href="mailto:zhngjah3@outlook.com" class="hover:opacity-80">
                      {t(lang, 'aboutSection.contactUs')}
                    </a>
                  </div>
                </div>
              </div>
            </div>
          </div>
          
          <div class="space-y-6">
            <div class="glass-card p-6 rounded-2xl">
              <h3 class="text-white font-semibold mb-4">{t(lang, 'aboutSection.otherLinks')}</h3>
              <div class="space-y-3">
                <a href="#" id="members-link" class="flex items-center gap-3 p-3 rounded-xl bg-white/5 hover:bg-white/10 transition-colors group">
                  <svg class="w-5 h-5 text-gray-400 group-hover:text-blue-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                  </svg>
                  <div>
                    <p class="text-white text-sm font-medium">{t(lang, 'aboutSection.members')}</p>
                    <p class="text-gray-500 text-xs">{t(lang, 'aboutSection.membersDesc')}</p>
                  </div>
                </a>
                <a href="#" id="sponsors-link" class="flex items-center gap-3 p-3 rounded-xl bg-white/5 hover:bg-white/10 transition-colors group">
                  <svg class="w-5 h-5 text-gray-400 group-hover:text-blue-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" />
                  </svg>
                  <div>
                    <p class="text-white text-sm font-medium">{t(lang, 'aboutSection.sponsors')}</p>
                    <p class="text-gray-500 text-xs">{t(lang, 'aboutSection.sponsorsDesc')}</p>
                  </div>
                </a>
              </div>
            </div>
            
            <div class="glass-card p-6 rounded-2xl">
              <div class="space-y-3 text-xs text-gray-500">
                <p>{t(lang, 'aboutSection.cdn')}</p>
                <p class="pt-2 border-t border-white/10">{t(lang, 'aboutSection.copyright')}</p>
                <p>{t(lang, 'aboutSection.company')}</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </div>
  
  <nav class="fixed right-6 top-1/2 -translate-y-1/2 z-50 flex flex-col gap-4" id="pageDots">
    <button class="w-3 h-3 rounded-full bg-white/30 hover:bg-white/60 transition-all active-dot" data-target="0"></button>
    <button class="w-3 h-3 rounded-full bg-white/30 hover:bg-white/60 transition-all" data-target="1"></button>
    <button class="w-3 h-3 rounded-full bg-white/30 hover:bg-white/60 transition-all" data-target="2"></button>
    <button class="w-3 h-3 rounded-full bg-white/30 hover:bg-white/60 transition-all" data-target="3"></button>
    <button class="w-3 h-3 rounded-full bg-white/30 hover:bg-white/60 transition-all" data-target="4"></button>
  </nav>
  
  <MembersModal lang={lang} isOpen={false} onClose={() => {}} />
  <SponsorsModal lang={lang} isOpen={false} onClose={() => {}} />
  
  <script define:vars={{ productsData }}>
    window.productsData = productsData;
  </script>
  
  <script>
    // 倒计时功能 - 简化版
    (function() {
      function updateTimer() {
        try {
          const startDate = new Date('2022-12-14');
          const now = new Date();
          const diff = now - startDate;
          
          const days = Math.floor(diff / (1000 * 60 * 60 * 24));
          const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
          const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
          const seconds = Math.floor((diff % (1000 * 60)) / 1000);
          
          const daysEl = document.getElementById('timer-days');
          const hoursEl = document.getElementById('timer-hours');
          const minutesEl = document.getElementById('timer-minutes');
          const secondsEl = document.getElementById('timer-seconds');
          
          if (daysEl) daysEl.textContent = days;
          if (hoursEl) hoursEl.textContent = hours;
          if (minutesEl) minutesEl.textContent = minutes;
          if (secondsEl) secondsEl.textContent = seconds;
        } catch (e) {
          console.error('Timer error:', e);
        }
      }
      
      // 初始化并启动计时器
      updateTimer();
      setInterval(updateTimer, 1000);
    })();
  </script>
  
  <style is:global>
    .active-dot {
      background-color: white !important;
      transform: scale(1.3);
    }
    
    .product-nav-btn.active {
      transform: scale(1.25);
    }
    
    .product-transition {
      transition: opacity 0.3s ease-in-out, transform 0.3s ease-in-out;
    }
    
    .product-hidden {
      opacity: 0;
      transform: scale(0.95);
    }
    
    .timer-value {
      display: inline-block;
      min-width: 2em;
      text-align: center;
      font-weight: bold;
      color: white;
    }
  </style>
  
  <script is:inline>
    const wrapper = document.getElementById('fullpageWrapper');
    const dots = document.querySelectorAll('#pageDots button');
    const sections = document.querySelectorAll('.fullpage-section');
    let currentIndex = 0;
    let isScrolling = false;
    const scrollTimeout = 600;

    function updateActiveDot() {
      dots.forEach((dot, index) => {
        dot.classList.toggle('active-dot', index === currentIndex);
      });
    }

    function scrollToSection(index) {
      if (isScrolling || index < 0 || index >= sections.length) return;
      isScrolling = true;
      currentIndex = index;
      sections[index].scrollIntoView({ behavior: 'smooth', block: 'start' });
      updateActiveDot();
      
      setTimeout(() => {
        isScrolling = false;
      }, scrollTimeout);
    }

    // 暴露全局滚动函数
    window.scrollToSection = scrollToSection;

    // 点击导航点跳转
    dots.forEach(dot => {
      dot.addEventListener('click', () => {
        const target = parseInt(dot.dataset.target);
        scrollToSection(target);
      });
    });

    // 监听滚动更新当前section
    const observerOptions = {
      root: wrapper,
      threshold: 0.6
    };

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          currentIndex = parseInt(entry.target.dataset.index);
          updateActiveDot();
        }
      });
    }, observerOptions);

    sections.forEach(section => {
      observer.observe(section);
    });

    // 滚轮事件增强
    let wheelTimeout;
    wrapper.addEventListener('wheel', (e) => {
      e.preventDefault();
      
      clearTimeout(wheelTimeout);
      wheelTimeout = setTimeout(() => {
        if (isScrolling) return;
        
        if (e.deltaY > 0) {
          scrollToSection(currentIndex + 1);
        } else if (e.deltaY < 0) {
          scrollToSection(currentIndex - 1);
        }
      }, 30);
    }, { passive: false });

    // 键盘事件
    document.addEventListener('keydown', (e) => {
      if (isScrolling) return;
      
      if (e.key === 'ArrowDown' || e.key === 'PageDown') {
        e.preventDefault();
        scrollToSection(currentIndex + 1);
      } else if (e.key === 'ArrowUp' || e.key === 'PageUp') {
        e.preventDefault();
        scrollToSection(currentIndex - 1);
      }
    });

    // 初始化时检查URL锚点
    window.addEventListener('load', () => {
      if (window.location.hash === '#section1') {
        setTimeout(() => {
          scrollToSection(1);
        }, 100);
      }
      if (window.location.hash === '#section2') {
        setTimeout(() => {
          scrollToSection(2);
        }, 100);
      }
      if (window.location.hash === '#section3') {
        setTimeout(() => {
          scrollToSection(3);
        }, 100);
      }
      if (window.location.hash === '#section4') {
        setTimeout(() => {
          scrollToSection(4);
        }, 100);
      }
    });

    // 产品切换功能 - 使用JSON文件数据
    const products = window.productsData;
    const lang = document.documentElement.lang === 'zh' ? 'zh' : 'en';
    const currentProducts = products[lang];
    
    let productIndex = 0;
    const productNameEl = document.getElementById('product-name');
    const productDescEl = document.getElementById('product-desc');
    const productSmallIconEl = document.getElementById('product-small-icon');
    const productLargeImageEl = document.getElementById('product-large-image');
    const productLinksEl = document.getElementById('product-links');
    const productNavBtns = document.querySelectorAll('.product-nav-btn');
    
    let autoSwitchInterval;
    
    function updateProduct(index) {
      productIndex = index;
      const product = currentProducts[index];
      
      productNameEl.textContent = product.name;
      productDescEl.textContent = product.desc;
      
      const oldIconImg = productSmallIconEl.querySelector('img');
      if (oldIconImg) {
        oldIconImg.src = product.iconPath;
      }
      
      const oldImageImg = productLargeImageEl.querySelector('img');
      if (oldImageImg) {
        oldImageImg.src = product.imagePath;
      }
      
      // 更新按钮
      productLinksEl.innerHTML = '';
      product.links.forEach((link) => {
        const a = document.createElement('a');
        a.href = link.url;
        a.target = '_blank';
        a.rel = 'noopener noreferrer';
        a.className = 'glass-btn px-6 py-3 rounded-xl text-white font-medium hover:scale-105 transition-transform text-center';
        a.textContent = link.text;
        productLinksEl.appendChild(a);
      });
      
      productNavBtns.forEach((btn, i) => {
        btn.classList.toggle('active', i === index);
      });
    }
    
    function startAutoSwitch() {
      autoSwitchInterval = setInterval(() => {
        const nextIndex = (productIndex + 1) % currentProducts.length;
        updateProduct(nextIndex);
      }, 5000);
    }
    
    function stopAutoSwitch() {
      if (autoSwitchInterval) {
        clearInterval(autoSwitchInterval);
      }
    }
    
    productNavBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        stopAutoSwitch();
        const index = parseInt(btn.dataset.index);
        updateProduct(index);
        startAutoSwitch();
      });
    });
    
    // 开始自动切换
    startAutoSwitch();
    
    // 成员列表弹窗功能
    const membersLink = document.getElementById('members-link');
    const membersModal = document.getElementById('members-modal');
    
    if (membersLink && membersModal) {
      membersLink.addEventListener('click', (e) => {
        e.preventDefault();
        membersModal.classList.remove('opacity-0', 'pointer-events-none');
      });
    }
    
    // 赞助者列表弹窗功能
    const sponsorsLink = document.getElementById('sponsors-link');
    const sponsorsModal = document.getElementById('sponsors-modal');
    
    if (sponsorsLink && sponsorsModal) {
      sponsorsLink.addEventListener('click', (e) => {
        e.preventDefault();
        sponsorsModal.classList.remove('opacity-0', 'pointer-events-none');
      });
    }
  </script>
</BaseLayout>
