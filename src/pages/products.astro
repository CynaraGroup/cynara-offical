---
import BaseLayout from '../layouts/BaseLayout.astro';
import productsZh from '../data/products.zh.json' assert { type: 'json' };
import productsEn from '../data/products.en.json' assert { type: 'json' };
import { getLocaleFromUrl, t, type Locale } from '../i18n';
import { cynaraConfig } from '../config/cynara';

interface ProductLink {
  text: string;
  url: string;
}

interface ProductItem {
  name: string;
  desc: string;
  iconPath: string;
  imagePath: string;
  links: ProductLink[];
}

const lang = getLocaleFromUrl(Astro.url);
const productsData = {
  zh: productsZh,
  en: productsEn,
};
const products = (productsData as Record<Locale, ProductItem[]>)[lang] ?? [];
---

<BaseLayout
  title={t(lang, 'nav.products')}
  lang={lang}
  showVideoBackground={true}
  description={lang === 'zh' ? '浏览 Cynara 的全部产品与服务入口。' : 'Browse all Cynara products and service entries.'}
>
  <main class="relative z-10 mx-auto min-h-screen max-w-7xl px-5 py-20 pb-32 md:px-6 md:py-24">
    <div class="mb-9 flex flex-wrap items-end justify-between gap-5 md:mb-12 md:gap-6">
      <div>
        <a href={`${cynaraConfig.routes.home}#section2`} class="mb-5 inline-flex text-sm font-semibold text-blue-200/80 hover:text-white">
          ← {lang === 'zh' ? '返回首页产品' : 'Back to home products'}
        </a>
        <h1 class="text-3xl font-bold text-white md:text-6xl">{t(lang, 'products.title')}</h1>
      </div>
      <p class="max-w-xl text-base leading-7 text-gray-300">
        {lang === 'zh' ? '这里展示 Cynara 当前公开的全部产品项目。' : 'All public Cynara product projects are collected here.'}
      </p>
    </div>

    <div class="grid gap-4 md:grid-cols-2 md:gap-6 xl:grid-cols-3">
      {products.map((product) => (
        <article class="glass-card group overflow-hidden rounded-3xl">
          <div class="aspect-video bg-white/5">
            <img src={product.imagePath} alt={product.name} class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-105" />
          </div>
          <div class="p-5 md:p-6">
            <div class="mb-4 flex items-center gap-4">
              <img src={product.iconPath} alt="" class="h-12 w-12 object-contain" />
              <h2 class="text-xl font-bold text-white md:text-2xl">{product.name}</h2>
            </div>
            <p class="min-h-20 text-sm leading-7 text-gray-300">{product.desc}</p>
            <div class="mt-6 flex flex-wrap gap-3">
              {product.links.map((link) => (
                <a href={link.url} target="_blank" rel="noopener noreferrer" class="glass-btn rounded-xl px-4 py-2 text-sm font-semibold text-white hover:border-blue-300/40 hover:bg-blue-500/20">
                  {link.text}
                </a>
              ))}
            </div>
          </div>
        </article>
      ))}
    </div>
  </main>
</BaseLayout>
