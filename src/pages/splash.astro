---
import { defaultLocale, type Locale } from '../i18n';

function getLang(): Locale {
  const cookies = Astro.request.headers.get('cookie') || '';
  const langCookie = cookies.split(';').find(c => c.trim().startsWith('lang='));
  const lang = langCookie ? langCookie.split('=')[1] : defaultLocale;
  return (lang === 'zh' || lang === 'en') ? lang : defaultLocale;
}

const lang = getLang();
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Cynara</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    html, body {
      width: 100%;
      height: 100%;
      overflow: hidden;
      background: #000;
      font-family: 'Inter', sans-serif;
    }
    .splash-container {
      position: relative;
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    video {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      min-width: 100%;
      min-height: 100%;
      width: auto;
      height: auto;
      object-fit: cover;
    }
    .skip-btn {
      position: fixed;
      bottom: 40px;
      right: 40px;
      z-index: 100;
      padding: 12px 32px;
      background: rgba(255, 255, 255, 0.1);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255, 255, 255, 0.2);
      color: white;
      font-size: 14px;
      font-weight: 500;
      border-radius: 9999px;
      cursor: pointer;
      transition: all 0.3s ease;
    }
    .skip-btn:hover {
      background: rgba(255, 255, 255, 0.2);
      transform: scale(1.05);
    }
    .logo-overlay {
      position: absolute;
      z-index: 10;
      display: flex;
      align-items: center;
      gap: 16px;
      opacity: 0;
      animation: fadeIn 1s ease forwards 0.5s;
    }
    @keyframes fadeIn {
      to { opacity: 1; }
    }
    .logo-overlay img {
      width: 48px;
      height: 48px;
      filter: brightness(2);
    }
    .logo-overlay span {
      font-size: 24px;
      font-weight: 600;
      color: white;
      letter-spacing: 2px;
    }
  </style>
</head>
<body>
  <div class="splash-container">
    <video id="splashVideo" autoplay muted playsinline>
      <source src="/assets/video/begin.mp4" type="video/mp4" />
    </video>
    <div class="logo-overlay">
      <img src="/assets/images/logo.svg" alt="Cynara" />
      <span>CYNARA</span>
    </div>
    <button class="skip-btn" id="skipBtn">跳过</button>
  </div>

  <script is:inline>
    const video = document.getElementById('splashVideo');
    const skipBtn = document.getElementById('skipBtn');

    function enterHome() {
      window.location.href = '/';
    }

    video.addEventListener('ended', enterHome);
    skipBtn.addEventListener('click', enterHome);

    video.addEventListener('error', () => {
      enterHome();
    });
  </script>
</body>
</html>
