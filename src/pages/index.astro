---
import { defaultLocale, type Locale } from '../i18n';

function getLang(): Locale {
  // 1. 先从 URL 参数获取
  const url = new URL(Astro.request.url);
  const langFromUrl = url.searchParams.get('lang');
  if (langFromUrl === 'zh' || langFromUrl === 'en') {
    return langFromUrl;
  }
  
  // 2. 再从 cookie 获取
  const cookies = Astro.request.headers.get('cookie') || '';
  const langCookie = cookies.split(';').find(c => c.trim().startsWith('lang='));
  const lang = langCookie ? langCookie.split('=')[1] : defaultLocale;
  return (lang === 'zh' || lang === 'en') ? lang : defaultLocale;
}

const lang = getLang();
---

<!DOCTYPE html>
<html lang={lang}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Cynara</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    html, body {
      width: 100%;
      height: 100%;
      overflow: hidden;
      background: #000;
      font-family: 'Inter', sans-serif;
    }
    .splash-container {
      position: relative;
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: transform 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    }
    .splash-container.slide-up {
      transform: translateY(-100%);
    }
    video {
      position: absolute;
      top: 50%;
      left: 50%;
      transform: translate(-50%, -50%);
      min-width: 100%;
      min-height: 100%;
      width: auto;
      height: auto;
      object-fit: cover;
    }
    .skip-btn {
      position: fixed;
      bottom: 40px;
      right: 40px;
      z-index: 100;
      padding: 12px 32px;
      background: rgba(255, 255, 255, 0.1);
      backdrop-filter: blur(10px);
      border: 1px solid rgba(255, 255, 255, 0.2);
      color: white;
      font-size: 14px;
      font-weight: 500;
      border-radius: 9999px;
      cursor: pointer;
      transition: all 0.3s ease;
    }
    .skip-btn:hover {
      background: rgba(255, 255, 255, 0.2);
      transform: scale(1.05);
    }
  </style>
</head>
<body>
  <div class="splash-container" id="splashContainer">
    <video id="splashVideo" autoplay muted playsinline>
    </video>
    <button class="skip-btn" id="skipBtn">跳过</button>
  </div>

  <script is:inline>
    const video = document.getElementById('splashVideo');
    const skipBtn = document.getElementById('skipBtn');
    const splashContainer = document.getElementById('splashContainer');
    const videoUrl = 'https://s.mahiro.work/d/cynara-offical/begin.mp4?sign=EV_Zz9Q2oblkZSHcm0E6MI1ugKe9hM3DfCyFocXaekE=:0';

    async function loadVideo() {
      try {
        const cache = await caches.open('cynara-video-cache');
        let response = await cache.match(videoUrl);
        
        if (!response) {
          response = await fetch(videoUrl);
          if (response.ok) {
            cache.put(videoUrl, response.clone());
          }
        }
        
        if (response && response.ok) {
          const blob = await response.blob();
          video.src = URL.createObjectURL(blob);
        } else {
          video.src = videoUrl;
        }
      } catch (err) {
        video.src = videoUrl;
      }
    }
    loadVideo();

    function enterHome() {
      splashContainer.classList.add('slide-up');
      
      // 保留 URL 语言参数
      const currentUrl = new URL(window.location.href);
      const lang = currentUrl.searchParams.get('lang');
      
      setTimeout(() => {
        let targetUrl = '/home';
        if (lang) {
          targetUrl += `?lang=${lang}`;
        }
        window.location.href = targetUrl;
      }, 600);
    }

    video.addEventListener('ended', enterHome);
    skipBtn.addEventListener('click', enterHome);

    video.addEventListener('error', () => {
      enterHome();
    });
  </script>
</body>
</html>
