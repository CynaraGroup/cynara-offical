---
import BaseLayout from '../layouts/BaseLayout.astro';
import partnersData from '../data/partners.json' assert { type: 'json' };
import { getLocaleFromUrl, t } from '../i18n';
import { cynaraConfig } from '../config/cynara';

interface PartnerItem {
  name: string;
  logo: string;
  url: string;
}

const lang = getLocaleFromUrl(Astro.url);
const partners = partnersData.partners as PartnerItem[];
---

<BaseLayout
  title={t(lang, 'nav.partners')}
  lang={lang}
  showVideoBackground={true}
  description={lang === 'zh' ? '浏览 Cynara 的全部合作伙伴。' : 'Browse all Cynara partners.'}
>
  <main class="relative z-10 mx-auto min-h-screen max-w-7xl px-5 py-20 pb-32 md:px-6 md:py-24">
    <div class="mb-9 flex flex-wrap items-end justify-between gap-5 md:mb-12 md:gap-6">
      <div>
        <a href={`${cynaraConfig.routes.home}#section3`} class="mb-5 inline-flex text-sm font-semibold text-blue-200/80 hover:text-white">
          ← {lang === 'zh' ? '返回首页合作伙伴' : 'Back to home partners'}
        </a>
        <h1 class="text-3xl font-bold text-white md:text-6xl">{t(lang, 'partners.title')}</h1>
      </div>
      <p class="max-w-xl text-base leading-7 text-gray-300">
        {lang === 'zh' ? '感谢这些伙伴与 Cynara 一起创造更好的服务体验。' : 'Thanks to these partners for creating better service experiences with Cynara.'}
      </p>
    </div>

    <div class="grid grid-cols-2 gap-4 sm:grid-cols-2 md:gap-6 lg:grid-cols-4">
      {partners.map((partner) => (
        <a
          href={partner.url}
          target="_blank"
          rel="noopener noreferrer"
          class="partner-card glass-card group flex aspect-[4/3] items-center justify-center overflow-hidden rounded-3xl p-3 transition-all duration-300 hover:scale-[1.03] md:p-5"
        >
          <img src={partner.logo} alt={partner.name} class="h-full w-full object-contain opacity-90 transition-transform duration-500 group-hover:scale-105" />
          <span class="absolute inset-x-5 bottom-5 rounded-2xl bg-black/50 px-4 py-3 text-center text-sm font-semibold text-white opacity-0 backdrop-blur-md transition-opacity duration-300 group-hover:opacity-100">
            {partner.name}
          </span>
        </a>
      ))}
    </div>
  </main>
</BaseLayout>
